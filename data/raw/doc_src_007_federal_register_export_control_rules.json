lass=\"boolean required\" required=\"required\" type=\"checkbox\" value=\"1\" name=\"site_feedback[technical_help]\" id=\"site_feedback_technical_help\" /><abbr title=\"required\">*</abbr> I am requesting technical help.</label></div>\n\n          <div class=\"actions\">\n            <input type=\"submit\" name=\"commit\" value=\"Request Help\" class=\"btn btn-primary btn-medium\" data-site-feedback-target=\"submitButton\" data-disable-with=\"Request Help\" />\n          </div>\n</form>      </div>\n\n      <div class=\"loader-container\"\n        data-site-feedback-target=\"loaderContainer\">\n        <div class=\"loader-wrapper\">\n          <img src=\"/assets/orange-loader-275e1783.svg\"\n            alt=\"Loading...\" class=\"loader-image\">\n        </div>\n      </div>\n    </div>\n  </div>\n</div>\n\n        </div>\n      </div>\n\n      <button type=\"button\"\n        class=\"btn btn-secondary btn-medium site-feedback-button\"\n        data-action=\"click->site-feedback#openModal\"\n        aria-label=\"Open site help form\">\n\n        <svg class=\"svg-icon svg-icon-chat \"><use xlink:href=\"/assets/ofr-icons-5f5559c5.svg#chat\"></use></svg>\n        <span class=\"desktop-only\">Site Help</span>\n      </button>\n    </div>\n\n  </body>\n</html>\n",
